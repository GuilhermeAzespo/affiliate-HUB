{
  "name": "afiliadobot",
  "version": "1.0.0",
  "description": "Disparador de mensagens multi-plataforma para afiliados (ML + Shopee) via WhatsApp",
  "type": "module",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "node --watch src/server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "build:all": "npm run frontend:build"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@whiskeysockets/baileys": "^6.7.9",
    "cheerio": "^1.0.0-rc.12",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
